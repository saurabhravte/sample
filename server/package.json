{
  "name": "@momentum/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo ok",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:migrate:corsair": "tsx scripts/migrate-corsair.ts",
    "perf": "node scripts/perf-check.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@corsair-dev/github": "latest",
    "@corsair-dev/gmail": "latest",
    "@corsair-dev/googlecalendar": "latest",
    "@corsair-dev/mcp": "latest",
    "@corsair-dev/slack": "latest",
    "@momentum/shared": "workspace:*",
    "argon2": "^0.41.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "corsair": "latest",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "nanoid": "^5.0.7",
    "pg": "^8.13.0",
    "pg-boss": "^10.1.5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
