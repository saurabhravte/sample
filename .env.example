# ─── Core ────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
WEB_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:4000

# Postgres (needs pgvector extension; see docker-compose.yml)
DATABASE_URL=postgres://momentum:momentum@localhost:5432/momentum

# ─── Corsair ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# NEVER commit. Use a DIFFERENT key in prod. Losing it = losing all stored credentials.
CORSAIR_KEK=

# ─── Auth ────────────────────────────────────────────────────────────────
# openssl rand -base64 32
SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# ─── Integrations (OAuth apps the user connects via Corsair) ────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── AI ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Cheap model for classification, better model for the agent
AI_CLASSIFIER_MODEL=claude-haiku-4-5-20251001
AI_AGENT_MODEL=claude-sonnet-4-6

# ─── Webhooks ────────────────────────────────────────────────────────────
# ngrok http 4000  →  paste the https URL here for local webhook testing
WEBHOOK_PUBLIC_URL=
WEBHOOK_SIGNING_SECRET=
